{
  "name": "freelancer-copilot",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbo",
    "dev:clean": "rm -rf .next && next dev --turbo",
    "test": "vitest run --exclude tests/e2e/**",
    "test:ui": "vitest --ui --exclude tests/e2e/**",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:create-schema": "dotenv -e .env -- tsx scripts/create-schema.ts",
    "db:push:dev": "dotenv -e .env -- drizzle-kit push",
    "db:studio": "dotenv -e .env -- drizzle-kit studio",
    "db:generate": "dotenv -e .env -- drizzle-kit generate",
    "db:migrate": "dotenv -e .env -- drizzle-kit migrate"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.78",
    "@ai-sdk/openai": "^3.0.64",
    "@ai-sdk/react": "^3.0.186",
    "ai": "^6.0.184",
    "drizzle-orm": "^0.45.2",
    "next": "16.2.6",
    "next-auth": "5.0.0-beta.31",
    "postgres": "^3.4.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "prettier": "^3.8.3",
    "tailwindcss": "^4",
    "tsx": "^4.22.0",
    "typescript": "^5",
    "vitest": "^4.1.6"
  }
}
