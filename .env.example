# Database
DATABASE_URL=postgresql://neondb_owner:...

# AI Providers
ANTHROPIC_API_KEY=sk-ant-api...
OPENAI_API_KEY=

# Auth
AUTH_SECRET=
AUTH_PASSWORD=
NEXTAUTH_URL=http://localhost:3005

# AI model override (optional, defaults to claude-sonnet-4-5)
AI_MODEL=

# Vercel Cron (generate with: openssl rand -hex 32)
CRON_SECRET=

# Browser extension API key (generate with: openssl rand -hex 16)
EXTENSION_API_KEY=

# Discord webhook for weekly digest (optional)
DISCORD_WEBHOOK_URL=
